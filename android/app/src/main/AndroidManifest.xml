<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- For AI photo import: taking a photo of a food/meal to share to an
         AI chat app. -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-feature android:name="android.hardware.camera" android:required="false"/>

    <!-- For the in-app update checker/downloader (Scampi isn't distributed
         through the Play Store, so it self-updates via a GitHub release). -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"/>

    <!-- Local notifications (fasting completion reminders, etc.) — all
         on-device scheduling, no push/FCM. RECEIVE_BOOT_COMPLETED lets a
         scheduled notification survive a device reboot; the exact-alarm
         permissions are deliberately NOT requested since notifications are
         scheduled with inexact (allow-while-idle) timing, which doesn't
         need them. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <uses-permission android:name="android.permission.VIBRATE"/>

    <!-- Used only to estimate Suhoor/Iftar (Fajr/Maghrib) times for a
         Ramadan fast via an on-device calculation — coarse accuracy is
         enough, and nothing about location ever leaves the device. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>

    <!-- Health Connect (steps + sleep sync from Google Fit/Samsung
         Health/wearables) — opt-in via Profile settings. Also satisfies the
         "health" foreground-service-type requirement below (Android
         requires the app to hold ACTIVITY_RECOGNITION or BODY_SENSORS to
         start a health-type foreground service). -->
    <uses-permission android:name="android.permission.health.READ_STEPS"/>
    <uses-permission android:name="android.permission.health.READ_SLEEP"/>
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION"/>

    <!-- Live Workout Session: a foreground service (via
         flutter_foreground_task) keeps the session's timer/notification
         running while the app is backgrounded or removed from Recents,
         the same way music apps keep background audio alive. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_HEALTH"/>

    <application
        android:label="scampi"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Lets Health Connect show its permissions screen for this app. -->
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>
        <!-- Health Connect's permissions screen links back to a privacy
             policy for the requesting app; MainActivity just needs to be
             reachable as that target. -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>
        <!-- flutter_foreground_task's service, for the live Workout
             Session. Deliberately no android:stopWithTask — leaving it
             unset (defaults to false) is what lets the session survive
             the app being swiped away from Recents, matching the
             TikTok-background-audio behavior this feature is modeled on.
             Warning (per plugin docs): do not change the service name. -->
        <service
            android:name="com.pravera.flutter_foreground_task.service.ForegroundService"
            android:foregroundServiceType="health"
            android:exported="false" />
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Health Connect: check whether it's installed. -->
        <package android:name="com.google.android.apps.healthdata" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
    </queries>
</manifest>
